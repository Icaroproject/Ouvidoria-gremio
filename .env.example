# Copie este arquivo para .env e preencha com seus dados reais.
# O arquivo .env NUNCA deve ser commitado no repositório.

DB_HOST=localhost
DB_NAME=dbouvidoria
DB_USER=root
DB_PASS=

# APP_URL e BASE_URL são detectados automaticamente.
# Descomente e ajuste abaixo SOMENTE se a detecção automática não funcionar:
# APP_URL=http://localhost/projeto_final
# BASE_URL=/projeto_final/

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu_email@gmail.com
MAIL_PASSWORD=sua_senha_de_app_aqui
MAIL_FROM_ADDRESS=seu_email@gmail.com
MAIL_FROM_NAME=Ouvidoria do Grêmio Escolar - EEEP Dom Walfrido

# Nome da escola exibido nos e-mails automáticos.
# Altere aqui se o sistema for usado por outra instituição.
SCHOOL_NAME=EEEP Dom Walfrido Teixeira Vieira
SCHOOL_SHORT=Dom Walfrido

# Habilitar modo de debug/desenvolvimento (debug.php só funciona com DEV_MODE=true).
# NUNCA defina como true em produção.
# DEV_MODE=true
